{
    "name": "svelte-calendar-lib",
    "version": "0.1.0",
    "type": "module",
    "description": "Generic, environment-agnostic Calendar library for TypeScript/Svelte",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "dev": "vite",
        "build": "vite build && tsc --emitDeclarationOnly",
        "test": "vitest run",
        "test:watch": "vitest",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "demo": "vite --open --port 5177",
        "example:demo": "vite --open",
        "allowedCommit": "git commit -m ",
        "test:e2e": "npx playwright test",
        "test:e2e:preview": "vite preview"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.2.3",
        "jsdom": "^28.1.0",
        "luxon": "^3.7.2",
        "playwright": "^1.58.2",
        "svelte": "^5.51.2",
        "svelte-check": "^4.4.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "svelte": "^4.0.0 || ^5.0.0"
    }
}
